# Copy this file to .env and fill in the values before running docker compose.

# PostgreSQL — used by docker-compose db service and DATABASE_URL below
# H-7: never commit a real password; use a strong random value in production
POSTGRES_PASSWORD=change-me-in-production

# Database — automatically constructed from POSTGRES_PASSWORD in docker-compose
# Set this explicitly when running the backend outside of Docker
DATABASE_URL=postgresql+asyncpg://gitsanity:change-me-in-production@localhost:5432/gitsanity

# GitHub OAuth App (create one at https://github.com/settings/developers)
# Production callback URL: https://<your-railway-backend>.up.railway.app/auth/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# Optional: personal access token for ingestion (raises GitHub API rate limits)
GITHUB_TOKEN=

# JWT / cookie signing — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
# Set PRODUCTION=true in Railway to enable secure cookies and samesite=none (cross-domain SPA mode)
PRODUCTION=false
# Set FRONTEND_URL in Railway to your Vercel URL: https://<your-app>.vercel.app
FRONTEND_URL=http://localhost:3000
# Set CORS_ORIGINS in Railway to your Vercel URL: ["https://<your-app>.vercel.app"]
CORS_ORIGINS=["http://localhost:3000"]

# Frontend build — set to deployed Railway backend URL in Vercel dashboard as env var
NEXT_PUBLIC_API_URL=http://localhost:8000
